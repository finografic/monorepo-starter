# Environment Configuration Example
# Copy this file to .env.development, .env.production, etc. and fill in your values

# GitHub Token
NPM_TOKEN=your-github-token-here

# Application Environment
NODE_ENV=development

# API Server Configuration
API_PROTOCOL=http
API_HOST=localhost
API_PORT=4040
API_BASE_PATH=/api

# Client Configuration
CLIENT_PROTOCOL=http
CLIENT_HOST=localhost
CLIENT_PORT=3000

# Database Configuration
DB_HOST=localhost
DB_USER=admin
DB_PASS=
DB_NAME=development.sqlite.db
DB_DIALECT=sqlite
DB_PORT=0

# Authentication
AUTH_SECRET=your-super-secret-auth-key-minimum-32-characters-long
AUTH_URL=http://localhost:4040
AUTH_COOKIE_PREFIX=touch-monorepo
TOKEN_COOKIE_SUFFIX=session_token
DATA_COOKIE_SUFFIX=session_data


