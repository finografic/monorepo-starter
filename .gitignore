# =============================================================================
# BUILD ARTIFACTS
# =============================================================================

# Build outputs
dist/
build/
.turbo/

# Panda CSS — generated at build time
styled-system/

# TypeScript
*.tsbuildinfo

# Production deployment build artifacts (regenerated each build)
deployments/

# =============================================================================
# DEPENDENCIES
# =============================================================================

# Dependencies
node_modules/

# =============================================================================
# ENVIRONMENT FILES
# =============================================================================

# Environment files
.env
.env.development
.env.production
.env.local
.env.*.local

# Keep example files
!.env.example

# =============================================================================
# AGENT FILES
# =============================================================================

# Agents
.agents/
!.agents/handoff.md
.codex/
.claude/
!.claude/settings.json
.worktrees/

# =============================================================================
# DATABASE FILES
# =============================================================================

# Database files (keep structure)
*.db
*.sqlite
*.sqlite3
*.db-journal

# Keep data structure but ignore contents
data/db/
data/uploads/

# Keep migrations
!data/migrations/

# =============================================================================
# IDE
# =============================================================================

# IDE
.cursor/**
!.cursor/.gitkeep
!.cursor/rules/
!.vscode/settings.json
.idea/
*.swp
*.swo

# =============================================================================
# WEB SERVER
# =============================================================================

# HTTP client cookie files (generated by curl, wget, etc.)
cookies.txt
cookies_*.txt

# default folders
cgi-bin/
fcgi-bin/
html/

# =============================================================================
# ARCHIVE FILES
# =============================================================================

# Archive files
*.tar
*.tar.gz
*.tgz
*.zip

# =============================================================================
# DEVELOPMENT / DEBUG FILES
# =============================================================================

# Package manager files
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Log files
logs/
*.log

# Debugging files
*.debug
debug.log

# Docs
docs/drafts/

# Coverage
coverage/

# =============================================================================
# SYSTEM FILES
# =============================================================================

# macOS
.DS_Store
**Thumbs.db

