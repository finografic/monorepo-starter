{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "env.server": ["./env.server"],
      "db": ["./src/db"],
      "db/*": ["./src/db/*"],
      "lib/*": ["./src/lib/*"],
      "routes/*": ["./src/routes/*"],
      "utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "env.server.ts"],
  "exclude": ["node_modules", "dist"]
}
