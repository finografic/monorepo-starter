{
  "name": "@workspace/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "---------- DEV": "-------------------------------------------------------",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "·········· BUILD": "·····················································",
    "build": "tsdown",
    "·········· CLEAN": "·····················································",
    "clean": "rm -rf dist",
    "·········· LINTING": "····················································",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c oxlint.config.ts"
  },
  "dependencies": {
    "@hono/auth-js": "1.0.17",
    "@hono/node-server": "1.19.9",
    "@hono/standard-validator": "0.2.2",
    "@workspace/config": "workspace:*",
    "hono": "^4.11.9",
    "hono-openapi": "1.3.0",
    "hono-pino": "0.10.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
