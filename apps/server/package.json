{
  "name": "@workspace/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsx watch src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --detach",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "typecheck": "tsc --noEmit",
    "·········· DB:BATCH": "··················································",
    "db:reset": "pnpm db:drop && pnpm db:migrations:generate && pnpm db:migrations:run && pnpm db:migrations:auth && pnpm db:setup",
    "db:setup": "NODE_OPTIONS='--import tsx' db-setup -y",
    "·········· DB:UTILS": "··················································",
    "db:drop": "rm -rf ../../data/*.sqlite.db ../../data/migrations",
    "db:create": "drizzle-kit push --config ./drizzle.config.ts",
    "db:migrations:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrations:auth": "tsx src/db/utils/seed.ts user",
    "db:migrations:seed": "tsx src/db/utils/seed.ts",
    "db:migrations:run": "tsx src/db/utils/migrate.ts",
    "db:views:create": "tsx src/db/utils/create-view.ts all",
    "db:views:create:single": "tsx src/db/utils/create-view.ts",
    "db:cleanup:short-keys": "tsx src/scripts/cleanup-short-keys.ts",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.0",
    "@hono/auth-js": "^1.0.17",
    "@hono/node-server": "^1.19.0",
    "@hono/standard-validator": "^0.2.0",
    "@scalar/hono-api-reference": "^0.10.19",
    "@workspace/config": "workspace:*",
    "better-sqlite3": "^11.9.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-valibot": "^0.4.2",
    "hono": "^4.12.27",
    "hono-openapi": "^1.3.0",
    "hono-pino": "^0.10.3",
    "http-status-codes": "^2.3.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.10.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
