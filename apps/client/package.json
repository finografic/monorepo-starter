{
  "name": "@workspace/client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "concurrently -n panda,vite \"pnpm panda:watch\" \"vite\"",
    "build": "pnpm panda:codegen && tsc --project tsconfig.json && vite build",
    "start": "vite preview",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm panda:clean && pnpm --package=@finografic/project-scripts dlx purge-builds --detach",
    "·········· LINTING": "···················································",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c oxlint.config.ts",
    "·········· CODEGEN": "···················································",
    "panda:watch": "panda --watch",
    "panda:codegen": "panda codegen && panda cssgen",
    "panda:clean": "panda codegen --clean"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@finografic/design-system": "^1.18.2",
    "@tanstack/react-query": "^5.101.1",
    "@workspace/ui": "workspace:*",
    "hono": "^4.12.27",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.1.0",
    "vitest": "^4.0.18"
  }
}
