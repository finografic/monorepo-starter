{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "context/*": ["./src/context/*"],
      "lib/api": ["./src/lib/api"],
      "lib/*": ["../server/src/lib/*"],
      "providers/*": ["./src/providers/*"],
      "queries/*": ["./src/queries/*"],
      "@workspace/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "hooks/*": ["../../packages/ui/src/hooks/*"],
      "ui/*": ["../../packages/ui/src/components/*"],
      "utils": ["../../packages/ui/src/lib/utils"],
      "env.server": ["../server/env.server"],
      "db": ["../server/src/db"],
      "db/*": ["../server/src/db/*"],
      "middlewares/*": ["../server/src/middlewares/*"],
      "routes/*": ["../server/src/routes/*"],
      "types/*": ["../server/src/types/*"],
      "utils/*": ["../server/src/utils/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
