{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "paths": {
      "@styled-system/*": ["./styled-system/*"],
      "@styled-system/css": ["./styled-system/css"],
      "@styled-system/jsx": ["./styled-system/jsx"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "styled-system"]
}
