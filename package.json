{
  "name": "@finografic/monorepo-starter",
  "version": "0.0.1",
  "private": true,
  "description": "Selective-extraction pnpm monorepo starter project.",
  "keywords": [
    "finografic",
    "monorepo",
    "pnpm",
    "starter",
    "turborepo",
    "typescript"
  ],
  "homepage": "https://github.com/finografic/monorepo-starter",
  "bugs": {
    "url": "https://github.com/finografic/monorepo-starter/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://finografic.github.io/cv-justin-rankin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/monorepo-starter.git"
  },
  "type": "module",
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "·········· LINTING": "···················································",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "·········· TYPES": "·····················································",
    "typecheck": "turbo run typecheck",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean:dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "reset": "pnpm clean && pnpm install && pnpm syncpack:fix && pnpm build",
    "·········· DEPS": "······················································",
    "deps:update": "pnpm update --latest --recursive",
    "verify:deps": "pnpm -r exec pnpm install --no-frozen-lockfile",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest --recursive",
    "·········· UTILS": "·····················································",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@finografic/md-lint": "^0.9.6",
    "@finografic/oxc-config": "^2.0.0",
    "@finografic/project-scripts": "^1.3.3",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "syncpack": "^13.0.4",
    "tsx": "^4.22.3",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=22.17.1",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.33.0"
}
