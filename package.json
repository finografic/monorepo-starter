{
  "name": "@finografic/monorepo-starter",
  "version": "0.0.1",
  "private": true,
  "description": "Full-stack pnpm monorepo starter — Vite 8 + React 19 + React Router v7 client; Hono + Drizzle ORM + Auth.js API server; shadcn + Tailwind 4 UI package; shared Valibot-validated env config; Turborepo task orchestration; oxlint toolchain; role-based access control and OpenAPI docs with Scalar UI.",
  "keywords": [
    "finografic",
    "monorepo",
    "pnpm",
    "starter",
    "turborepo",
    "typescript"
  ],
  "homepage": "https://github.com/finografic/monorepo-starter",
  "bugs": {
    "url": "https://github.com/finografic/monorepo-starter/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://finografic.github.io/cv-justin-rankin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/monorepo-starter.git"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "turbo run dev --filter=@workspace/client --filter=@workspace/server",
    "dev:reset": "run-s reset",
    "dev:db:reset": "run-s db:reset",
    "start": "turbo run start --filter=@workspace/client --filter=@workspace/server",
    "build": "turbo run build",
    "test": "turbo run test",
    "·········· LINTING": "···················································",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "·········· TYPES": "·····················································",
    "typecheck": "turbo run typecheck",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean:dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "reset": "pnpm clean && pnpm install && pnpm syncpack:fix && pnpm build",
    "·········· DB": "··················································",
    "db:reset": "pnpm --filter @workspace/server db:reset",
    "db:studio": "pnpm --filter @workspace/server db:studio",
    "·········· DEPS": "······················································",
    "deps:update": "pnpm update --latest --recursive",
    "verify:deps": "pnpm -r exec pnpm install --no-frozen-lockfile",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest --recursive && pnpm update oxfmt --latest --recursive && pnpm update oxlint --latest --recursive",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest --recursive",
    "·········· UTILS": "·····················································",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@finografic/md-lint": "^0.16.6",
    "@finografic/oxc-config": "^2.8.2",
    "@finografic/project-scripts": "^1.5.4",
    "@types/node": "24.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "syncpack": "^13.0.4",
    "tsx": "^4.22.3",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=10.20.0"
  }
}
