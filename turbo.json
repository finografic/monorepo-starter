{
  "$schema": "https://v2-8-16.turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@workspace/build-deployment#build": {
      "cache": false,
      "dependsOn": [],
      "outputs": []
    },
    "@workspace/scripts#build": {
      "cache": false,
      "outputs": []
    },
    "@workspace/core#build": {
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "@workspace/shared#build": {
      "dependsOn": ["@workspace/core#build"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "@workspace/i18n#build": {
      "dependsOn": ["@workspace/core#build", "@workspace/shared#build"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "@workspace/config#build": {
      "dependsOn": ["@workspace/i18n#build"],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "@workspace/design-system#build": {
      "dependsOn": [
        "@workspace/core#build",
        "@workspace/shared#build",
        "@workspace/i18n#build",
        "@workspace/config#build"
      ],
      "outputs": ["dist/**"]
    },
    "@workspace/server#build": {
      "dependsOn": [
        "@workspace/core#build",
        "@workspace/shared#build",
        "@workspace/i18n#build",
        "@workspace/config#build"
      ],
      "outputs": ["dist/**", "*.tsbuildinfo"]
    },
    "@workspace/client#build": {
      "dependsOn": [
        "@workspace/core#build",
        "@workspace/shared#build",
        "@workspace/i18n#build",
        "@workspace/config#build"
      ],
      "outputs": ["dist/**", "styled-system/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "env": ["NODE_ENV", "PORT"]
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
